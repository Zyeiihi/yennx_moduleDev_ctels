# .env.example — Copy to .env and fill in values
# DB settings (PostgreSQL)
DB_DRIVER=postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=mini_asm

# SQLite alternative (set DB_DRIVER=sqlite to use)
# DB_DRIVER=sqlite
# SQLITE_PATH=./mini_asm.db

# App settings
PORT=8080
FLASK_DEBUG=false
